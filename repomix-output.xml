  <link rel="stylesheet" href="css/styles.css" />
  <style>
    body { padding-top: 60px; }

    /* ── HERO ── */
    .elections-hero {
      padding: 72px 64px 48px;
      border-bottom: 1px solid var(--gray-100);
    }
    .elections-location-tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12px; font-weight: 500; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--gray-500);
      margin-bottom: 20px;
    }
    .loc-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--black); display: inline-block;
    }
    .elections-title {
      font-family: var(--serif); font-size: 56px;
      letter-spacing: -2px; line-height: 1.0;
      color: var(--black); margin-bottom: 10px;
      width: 420px;
    }
    .elections-subtitle {
      font-size: 16px; color: var(--gray-500); font-weight: 300;
      max-width: 440px; line-height: 1.5;
    }

    /* ── CAROUSEL ── */
    .carousel-section {
      padding: 40px 64px;
      border-bottom: 1px solid var(--gray-100);
      position: relative;
    }
    .carousel-track {
      display: flex; gap: 14px; overflow-x: auto;
      scrollbar-width: none; scroll-behavior: smooth;
      padding-bottom: 4px;
    }
    .carousel-track::-webkit-scrollbar { display: none; }

    /* ── EXPLORE SECTION ── */
    .explore-section { padding: 56px 64px; }
    .section-header {
      display: flex; align-items: flex-end;
      justify-content: space-between; margin-bottom: 36px;
    }
    .section-h2 {
      font-family: var(--serif); font-size: 34px;
      letter-spacing: -1px; color: var(--black);
      width: 420px;
    }

    /* ── FEATURED / TAKE A CLOSER LOOK ── */
    .featured-section { padding: 0 64px 56px; }
    .section-h3 {
      font-family: var(--serif); font-size: 26px;
      letter-spacing: -0.5px; color: var(--black);
      margin-bottom: 24px;
    }

    /* ── WHY VOTE ── */
    .why-vote-section {
      padding: 56px 64px;
      background: var(--gray-50);
      border-top: 1px solid var(--gray-100);
    }
    .section-h4 {
      font-family: var(--serif); font-size: 22px;
      letter-spacing: -0.5px; color: var(--black);
      margin-bottom: 24px;
    }
    .why-cards {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 16px;
    }
    .why-card {
      padding: 24px; background: var(--white);
      border: 1.5px solid var(--gray-100); border-radius: var(--radius);
    }
    .why-card .wc-icon { font-size: 28px; margin-bottom: 12px; }
    .why-card .wc-title { font-size: 15px; font-weight: 600; color: var(--black); margin-bottom: 6px; }
    .why-card .wc-text { font-size: 13px; color: var(--gray-500); line-height: 1.5; }

    /* ── VOTING ESSENTIALS ── */
    .essentials-section { padding: 56px 64px; }
    .section-h5 {
      font-family: var(--serif); font-size: 20px;
      letter-spacing: -0.3px; color: var(--black);
      margin-bottom: 24px;
    }
    .essentials-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px;
    }
    .essential-item {
      padding: 18px 20px; border: 1.5px solid var(--gray-100);
      border-radius: 12px; display: flex; align-items: center;
      gap: 12px; cursor: pointer; transition: all var(--transition);
      background: var(--white); text-decoration: none; color: inherit;
    }
    .essential-item:hover { border-color: var(--black); }
    .essential-item .ei-icon { font-size: 20px; flex-shrink: 0; }
    .essential-item .ei-text { font-size: 13px; font-weight: 500; color: var(--black); }
  </style>
</head>
