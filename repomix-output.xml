<script src="js/main.js"></script>
<script>
  const searchBtn   = document.getElementById('search-btn');
  const locationBtn = document.getElementById('location-btn');
  const zipInput    = document.getElementById('zip-input');
  const errorBox    = document.getElementById('error-box');

  function goToElections(address) {
    if (!address || address.trim().length < 3) {
      errorBox.innerHTML = '<div class="error-message">Please enter a valid ZIP code or address.</div>';
      return;
    }
    AppState.address = address.trim();
    AppState.zip = address.trim();
    saveState();
    window.location.href = 'elections.html';
  }

  searchBtn.addEventListener('click', () => goToElections(zipInput.value));

  zipInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') goToElections(zipInput.value);
  });

  locationBtn.addEventListener('click', async () => {
    locationBtn.textContent = 'Getting location…';
    locationBtn.disabled = true;
    try {
      const { lat, lng } = await getLocation();
      const address = await reverseGeocode(lat, lng);
      if (address) {
        goToElections(address);
      } else {
        // fallback — just go with coords
        goToElections(`${lat},${lng}`);
      }
    } catch (err) {
      errorBox.innerHTML = '<div class="error-message">Could not get location. Please enter your address manually.</div>';
      locationBtn.textContent = 'Use my current location';
      locationBtn.disabled = false;
    }
  });
</script>
</body>
