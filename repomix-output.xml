// ── Carousel ──────────────────────────────────────
function scrollCarousel(dir) {
  const track = document.getElementById('carousel');
  if (track) track.scrollBy({ left: dir * 200, behavior: 'smooth' });
}

function setActiveChip(el) {
  document.querySelectorAll('.district-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}

// ── ZIP input: Enter key ──────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const zip = document.getElementById('zip-input');
  if (zip) {
    zip.addEventListener('keydown', e => {
      if (e.key === 'Enter') window.location.href = 'elections.html';
    });
  }

  // Re-trigger fade-up animations on page load
  document.querySelectorAll('.fade-up').forEach(el => {
    el.style.animation = 'none';
    void el.offsetHeight;
    el.style.animation = '';
  });
});
