<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BallotGuide — Compare Candidates</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="css/styles.css" />
  <style>
    body { padding-top: 60px; }

    .compare-hero {
      padding: 64px 64px 40px;
      border-bottom: 1px solid var(--gray-100);
    }
    .compare-title {
      font-family: var(--serif); font-size: 48px; letter-spacing: -2px;
      margin-bottom: 10px;
    }
    .compare-subtitle { font-size: 15px; color: var(--gray-500); font-weight: 300; }

    .compare-grid { padding: 48px 64px; }

    .compare-sources {
      font-size: 12px; color: var(--gray-400); margin-top: 16px;
    }

    @media (max-width: 768px) {
      .compare-hero, .compare-grid { padding: 32px 24px; }
      .compare-title { font-size: 36px; }
      .compare-candidates { grid-template-columns: 80px 1fr 1fr !important; }
      .compare-cell { padding: 14px 12px !important; font-size: 12px !important; }
      .cc-header { padding: 16px 12px !important; }
      .cc-cand-name { font-size: 15px !important; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a class="nav-logo" href="index.html">BallotGuide</a>
    <div class="nav-links">
      <a href="elections.html">Elections</a>
      <a href="candidate.html">Candidates</a>
      <a href="compare.html">Compare</a>
      <a href="#">About</a>
    </div>
    <a class="nav-cta" href="index.html">Find My Ballot</a>
