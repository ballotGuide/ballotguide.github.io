*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --black: #0a0a0a;
  --gray-900: #1a1a1a;
  --gray-700: #3a3a3a;
  --gray-600: #4a4a4a;
  --gray-500: #6a6a6a;
  --gray-400: #8a8a8a;
  --gray-300: #c0c0c0;
  --gray-200: #e0e0e0;
  --gray-100: #f0f0f0;
  --gray-50: #f8f8f8;
  --white: #ffffff;
  --serif: 'DM Serif Display', Georgia, serif;
  --sans: 'DM Sans', system-ui, sans-serif;
  --radius: 16px;
  --transition: 0.22s cubic-bezier(0.4,0,0.2,1);
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--sans);
  background: var(--white);
  color: var(--black);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 48px; height: 60px;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid rgba(0,0,0,0.06);
}
.nav-logo {
  font-family: var(--serif); font-size: 22px; letter-spacing: -0.5px;
  color: var(--black); cursor: pointer; text-decoration: none;
}
.nav-links { display: flex; gap: 32px; }
.nav-links a {
  font-size: 14px; font-weight: 500; color: var(--gray-500);
  text-decoration: none; transition: color var(--transition);
}
.nav-links a:hover { color: var(--black); }
.nav-cta {
  padding: 8px 20px; background: var(--black); color: var(--white);
  border: none; border-radius: 100px; font-family: var(--sans);
  font-size: 13px; font-weight: 500; cursor: pointer;
  transition: opacity var(--transition); text-decoration: none;
  display: inline-flex; align-items: center;
}
.nav-cta:hover { opacity: 0.8; }

/* ── BACK NAV ── */
.back-nav {
  padding: 16px 64px 0;
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: var(--gray-500); cursor: pointer;
  transition: color var(--transition); text-decoration: none;
  width: fit-content;
}
.back-nav:hover { color: var(--black); }

/* ── BUTTONS ── */
.btn-primary {
  padding: 16px 28px; background: var(--black); color: var(--white);
  border: none; border-radius: 14px; font-family: var(--sans);
  font-size: 15px; font-weight: 500; cursor: pointer; white-space: nowrap;
  transition: opacity var(--transition), transform var(--transition);
  text-decoration: none; display: inline-flex; align-items: center;
}
.btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }
.btn-primary:active { transform: translateY(0); }

.btn-ghost {
  padding: 14px 20px; background: transparent; color: var(--gray-500);
  border: 1.5px solid var(--gray-200); border-radius: 14px;
  font-family: var(--sans); font-size: 14px; font-weight: 400;
  cursor: pointer; transition: all var(--transition);
  display: flex; align-items: center; gap: 8px; text-decoration: none;
}
.btn-ghost:hover { border-color: var(--gray-500); color: var(--black); }

/* ── ANIMATIONS ── */
.fade-up {
  opacity: 0; transform: translateY(24px);
  animation: fadeUp 0.5s cubic-bezier(0.4,0,0.2,1) forwards;
}
@keyframes fadeUp {
  to { opacity: 1; transform: translateY(0); }
}
.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }

/* ── SHARED SECTION LABELS ── */
.section-label {
  font-size: 11px; font-weight: 500; letter-spacing: 2px;
  text-transform: uppercase; color: var(--gray-400);
  margin-bottom: 20px;
}

/* ── TAGS ── */
.tag {
  padding: 6px 14px; border: 1.5px solid var(--gray-200);
  border-radius: 100px; font-size: 12px; font-weight: 500;
  color: var(--gray-600);
}
.tag.dem { border-color: #1a1a1a; background: var(--gray-50); }

/* ── DISTRICT CHIPS ── */
.district-chip {
  flex-shrink: 0; padding: 14px 22px;
  border: 1.5px solid var(--gray-200); border-radius: 100px;
  cursor: pointer; transition: all var(--transition);
  display: flex; flex-direction: column; gap: 2px;
  background: var(--white); min-width: 160px;
}
.district-chip:hover, .district-chip.active {
  border-color: var(--black); background: var(--black);
}
.district-chip:hover .chip-name,
.district-chip.active .chip-name { color: var(--white); }
.district-chip:hover .chip-sub,
.district-chip.active .chip-sub { color: rgba(255,255,255,0.5); }
.chip-name { font-size: 14px; font-weight: 500; color: var(--black); }
.chip-sub { font-size: 11px; color: var(--gray-400); }

/* ── ELECTION CARDS ── */
.election-cards {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}
.election-card {
  padding: 28px; border: 1.5px solid var(--gray-100); border-radius: var(--radius);
  cursor: pointer; transition: all var(--transition);
  display: flex; flex-direction: column; gap: 16px;
  background: var(--white); text-decoration: none; color: inherit;
}
.election-card:hover { border-color: var(--black); box-shadow: 0 8px 32px rgba(0,0,0,0.08); transform: translateY(-2px); }
.ec-top { display: flex; align-items: flex-start; justify-content: space-between; }
.ec-icon {
  width: 44px; height: 44px; background: var(--gray-50);
  border-radius: 12px; display: flex; align-items: center;
  justify-content: center; font-size: 22px;
}
.ec-count {
  font-size: 12px; font-weight: 500; color: var(--gray-400);
  background: var(--gray-50); padding: 4px 10px; border-radius: 100px;
}
.ec-title { font-family: var(--serif); font-size: 22px; letter-spacing: -0.5px; color: var(--black); }
.ec-offices { font-size: 13px; color: var(--gray-500); line-height: 1.5; }
.ec-arrow { font-size: 18px; color: var(--gray-300); align-self: flex-end; }

/* ── FEATURED BANNER ── */
.featured-banner {
  background: var(--black); color: var(--white);
  border-radius: var(--radius); padding: 40px 48px;
  display: flex; align-items: center; justify-content: space-between;
  cursor: pointer; transition: opacity var(--transition);
  gap: 32px; text-decoration: none;
}
.featured-banner:hover { opacity: 0.92; }
.fb-label {
  font-size: 11px; font-weight: 500; letter-spacing: 2px;
  text-transform: uppercase; color: rgba(255,255,255,0.4);
  margin-bottom: 12px;
}
.fb-title { font-family: var(--serif); font-size: 30px; letter-spacing: -1px; margin-bottom: 10px; color: var(--white); }
.fb-meta { font-size: 14px; color: rgba(255,255,255,0.5); font-weight: 300; }
.fb-cta {
  flex-shrink: 0; padding: 14px 26px;
  border: 1.5px solid rgba(255,255,255,0.25); border-radius: 100px;
  font-size: 14px; font-weight: 500; color: var(--white);
  white-space: nowrap;
}

/* ── COMPARE TILE ── */
.compare-tile {
  display: flex; align-items: center; gap: 12px;
  padding: 16px 22px; border: 1.5px solid var(--gray-200);
  border-radius: 14px; cursor: pointer;
  transition: all var(--transition); background: var(--white);
  max-width: 240px; text-decoration: none; color: inherit;
}
.compare-tile:hover { border-color: var(--black); }
.compare-icon {
  width: 36px; height: 36px; background: var(--gray-100);
  border-radius: 10px; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 18px;
}
.compare-tile-text .ct-title { font-size: 13px; font-weight: 600; color: var(--black); }
.compare-tile-text .ct-sub { font-size: 12px; color: var(--gray-500); }

/* ── TIMELINE ── */
.timeline { display: flex; flex-direction: column; gap: 0; }
.tl-item {
  display: flex; gap: 24px; position: relative;
  padding-bottom: 32px;
}
.tl-item:last-child { padding-bottom: 0; }
.tl-item:last-child .tl-line { display: none; }
.tl-left { display: flex; flex-direction: column; align-items: center; width: 60px; flex-shrink: 0; }
.tl-year { font-size: 12px; font-weight: 600; color: var(--gray-400); text-align: center; }
.tl-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--gray-300); margin: 6px 0; flex-shrink: 0;
}
.tl-dot.highlight { background: var(--black); }
.tl-line { width: 1px; flex: 1; background: var(--gray-100); min-height: 20px; }
.tl-content {
  flex: 1; padding: 14px 18px; border: 1.5px solid var(--gray-100);
  border-radius: 12px; background: var(--white);
}
.tl-event { font-size: 14px; font-weight: 500; color: var(--black); margin-bottom: 4px; }
.tl-source { font-size: 12px; color: var(--gray-400); }
.tl-badge {
  display: inline-block; padding: 3px 8px; border-radius: 100px;
  font-size: 11px; font-weight: 500; margin-top: 6px;
}
.tl-badge.vote { background: #f0f0f0; color: #555; }
.tl-badge.funding { background: #fff0f0; color: #c44; }
.tl-badge.bill { background: #f0fff4; color: #3a8; }

/* ── FUNDING BARS ── */
.funding-bar { margin-bottom: 12px; }
.funding-bar .fb-row { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px; }
.funding-bar .fb-label-text { color: var(--gray-600); }
.funding-bar .fb-amount { font-weight: 600; color: var(--black); }
.fb-track {
  height: 4px; background: var(--gray-100); border-radius: 100px; overflow: hidden;
}
.fb-fill { height: 100%; background: var(--black); border-radius: 100px; }

/* ── COMPARE TABLE ── */
.compare-candidates {
  display: grid; grid-template-columns: 200px 1fr 1fr; gap: 0;
  border: 1.5px solid var(--gray-100); border-radius: var(--radius); overflow: hidden;
}
.cc-header {
  background: var(--gray-50); padding: 24px 28px;
  border-bottom: 1.5px solid var(--gray-100);
  display: flex; flex-direction: column; gap: 4px;
}
.cc-header.label-col { background: var(--white); }
.cc-cand-name { font-family: var(--serif); font-size: 20px; letter-spacing: -0.5px; }
.cc-cand-party {
  font-size: 11px; font-weight: 500; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--gray-400);
}
.compare-row { display: contents; }
.compare-cell {
  padding: 20px 28px;
  border-bottom: 1px solid var(--gray-100);
  border-right: 1px solid var(--gray-100);
  font-size: 14px; color: var(--black); line-height: 1.5;
}
.compare-cell.category {
  font-size: 11px; font-weight: 600; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--gray-400);
  background: var(--white); display: flex; align-items: center;
}
.compare-cell.support { color: #2a7a4a; }
.compare-cell.oppose { color: #c44; }
.compare-cell:last-child { border-right: none; }

/* ── CAROUSEL NAV ── */
.carousel-nav {
  position: absolute; right: 64px; top: 40px;
  display: flex; gap: 8px;
}
.cnav-btn {
  width: 36px; height: 36px; border-radius: 50%;
  border: 1.5px solid var(--gray-200); background: var(--white);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all var(--transition);
}
.cnav-btn:hover { border-color: var(--black); background: var(--black); }
.cnav-btn:hover svg path { stroke: var(--white); }
.cnav-btn svg { width: 14px; height: 14px; }
.cnav-btn svg path { stroke: var(--gray-500); stroke-width: 2; fill: none; stroke-linecap: round; }

/* ── OR DIVIDER ── */
.or-divider {
  display: flex; align-items: center; gap: 16px;
  color: var(--gray-300); font-size: 13px;
}
.or-divider::before, .or-divider::after {
  content: ''; flex: 1; height: 1px; background: var(--gray-200);
}

/* ────────────────────────────────────────────
   RESPONSIVE
──────────────────────────────────────────── */
@media (max-width: 768px) {
  nav { padding: 0 20px; }
  .nav-links { display: none; }
  .back-nav { padding-left: 24px; }
  .elections-hero, .carousel-section, .explore-section,
  .featured-section { padding-left: 24px !important; padding-right: 24px !important; }
  .elections-title { width: auto !important; font-size: 40px !important; }
  .section-h2 { width: auto !important; }
  .candidate-hero { padding: 32px 24px !important; flex-direction: column !important; gap: 24px !important; }
  .candidate-name { font-size: 36px !important; }
  .candidate-body { grid-template-columns: 1fr !important; }
  .timeline-section, .candidate-sidebar { padding: 32px 24px !important; }
  .compare-hero, .compare-grid { padding: 32px 24px !important; }
  .compare-candidates { grid-template-columns: 100px 1fr 1fr !important; }
  .carousel-nav { display: none; }
}
</file>

