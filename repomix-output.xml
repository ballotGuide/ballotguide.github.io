  <!-- HERO -->
  <div class="compare-hero">
    <h1 class="compare-title">Compare Candidates</h1>
    <p class="compare-subtitle">U.S. House — District 13 · Illinois</p>
  </div>

  <!-- COMPARE TABLE -->
  <div class="compare-grid">
    <div class="compare-candidates">

      <!-- Header row -->
      <div class="cc-header label-col"></div>
      <div class="cc-header">
        <div class="cc-cand-name">Jane Smith</div>
        <div class="cc-cand-party">Democrat</div>
      </div>
      <div class="cc-header">
        <div class="cc-cand-name">Mark Davis</div>
        <div class="cc-cand-party">Republican</div>
      </div>

      <!-- Healthcare -->
      <div class="compare-row">
        <div class="compare-cell category">Healthcare</div>
        <div class="compare-cell support">Supports public option and Medicare expansion</div>
        <div class="compare-cell oppose">Opposes public option; supports private market solutions</div>
      </div>

      <!-- Energy -->
      <div class="compare-row">
        <div class="compare-cell category">Energy</div>
        <div class="compare-cell support">Supports renewable investment; phased fossil fuel reduction</div>
        <div class="compare-cell oppose">Supports domestic oil &amp; gas expansion; opposes carbon tax</div>
      </div>

      <!-- Education -->
      <div class="compare-row">
        <div class="compare-cell category">Education</div>
        <div class="compare-cell support">Supports tuition relief and increased Pell Grants</div>
        <div class="compare-cell">Supports school choice and vocational alternatives</div>
